---
// Author: Cascade (claude-sonnet-4-20250514)
// Date: 2026-02-23
// PURPOSE: Shared HTML shell — terminal/DAG aesthetic. Nav uses monospace prompt-style links.
//          Footer is structured columns. Subtle CSS grid background on body.
//          All pages extend this layout via <Base title="...">
// SRP/DRY check: Pass — single layout, all pages reuse
export interface Props {
  title: string;
  description?: string;
  hideNav?: boolean;
  hideFooter?: boolean;
  canonicalUrl?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  twitterCard?: 'summary' | 'summary_large_image';
  twitterSite?: string;
  twitterCreator?: string;
}
const {
  title,
  description = "VoynichLabs — generative computation, mathematical discovery, and AI research.",
  hideNav = false,
  hideFooter = false,
  canonicalUrl,
  ogImage,
  ogType = 'website',
  twitterCard = 'summary',
  twitterSite = '@82deutschmark',
  twitterCreator = '@82deutschmark',
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const navLinks = [
  { href: `${base}/`, label: 'index' },
  { href: `${base}/about`, label: 'about' },
  { href: `${base}/projects`, label: 'projects' },

  { href: `${base}/planexe`, label: 'planexe', color: 'text-purple-400' },

  { href: `${base}/simon`, label: 'simon' },
  { href: `${base}/team`, label: '🦞 swarm', color: 'text-rust-orange' },
  { href: `${base}/lobster-incubator`, label: '🧪 incubator', color: 'text-edge-green' },
  { href: `${base}/lobster-art-museum`, label: '🎨 museum', color: 'text-rust-orange' },
  { href: `${base}/research`, label: '📄 research', color: 'text-amber-400' },
  { href: `${base}/collaborators`, label: 'collaborate', color: 'text-node-blue' },
  { href: `${base}/claw`, label: '🦞 claw', color: 'text-rust-orange' },
  { href: `${base}/autonovel`, label: '📖 autonovel', color: 'text-amber-400' },
  { href: `${base}/voynich-manuscript`, label: '📜 voynich', color: 'text-stone-400' },
];
const mobileLinks = navLinks.slice(2, 6);
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}

    <meta property="og:title" content={`${title} | VoynichLabs`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    {ogImage && <meta property="og:image" content={ogImage} />}

    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:title" content={`${title} | VoynichLabs`} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    {twitterSite && <meta name="twitter:site" content={twitterSite} />}
    {twitterCreator && <meta name="twitter:creator" content={twitterCreator} />}

    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <title>{title} | VoynichLabs</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <!-- KaTeX for math rendering in LODA sections -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" />
  </head>
  <body class="bg-bg-primary text-text-primary font-sans antialiased min-h-screen relative">
    <!-- Subtle dot-grid background -->
    <div class="fixed inset-0 pointer-events-none z-0 opacity-[0.03]"
         style="background-image: radial-gradient(circle, #e8e8f0 0.5px, transparent 0.5px); background-size: 24px 24px;">
    </div>

    {!hideNav && (
      <!-- Nav — terminal style -->
      <nav class="fixed top-0 w-full z-50 bg-bg-primary/90 backdrop-blur-sm border-b border-border">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">
          <a href={`${base}/`} class="flex items-center gap-2 font-mono text-sm text-text-primary hover:text-node-blue transition-colors duration-200">
            <span>🦞</span>
            <span class="font-semibold tracking-tight">VoynichLabs</span>
          </a>
          <div class="hidden sm:flex items-center gap-1 font-mono text-xs text-text-muted">
            {navLinks.map((link, index) => (
              <div class="flex items-center gap-1" key={link.href}>
                <a
                  href={link.href}
                  class={`px-3 py-1.5 rounded transition-colors duration-200 ${link.color ?? 'text-text-muted'} hover:text-text-primary hover:bg-bg-surface`}
                >
                  {link.label}
                </a>
                {index < navLinks.length - 1 && <span class="text-border">/</span>}
              </div>
            ))}
            <span class="text-border">|</span>
            <a
              href="https://github.com/neoneye"
              target="_blank"
              rel="noopener"
              class="px-3 py-1.5 hover:text-text-primary hover:bg-bg-surface rounded transition-colors duration-200"
            >
              gh:neoneye
            </a>
          </div>
          <!-- Mobile nav -->
          <div class="sm:hidden flex items-center gap-3 font-mono text-xs text-text-muted">
            {mobileLinks.map((link) => (
              <a href={link.href} class="hover:text-text-primary transition-colors" key={link.href}>
                {link.label}
              </a>
            ))}
          </div>
        </div>
      </nav>
    )}

    <div class="relative z-10 pt-14">
      <slot />
    </div>

    {!hideFooter && (
      <!-- Footer — structured, no fluff -->
      <footer class="relative z-10 border-t border-border mt-24">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 text-sm">
            <!-- Col 1: Identity -->
            <div>
              <p class="font-mono text-xs text-text-muted uppercase tracking-widest mb-3">🦞 VoynichLabs</p>
              <p class="text-text-muted leading-relaxed">
                A research collective for generative computation, mathematical discovery, and AI research.
                Built around the work of Simon Strandgaard and his collaborators. Copenhagen, Denmark.
              </p>
              <p class="text-text-muted leading-relaxed mt-2 text-xs">
                Collaborators include <a href="https://markbarney.net" target="_blank" rel="noopener" class="hover:text-node-blue transition-colors">Mark Barney</a> — co-contributor on ARC-AGI tooling and datasets.
              </p>
            </div>
            <!-- Col 2: Navigation -->
            <div>
              <p class="font-mono text-xs text-text-muted uppercase tracking-widest mb-3">Navigate</p>
              <div class="flex flex-col gap-1.5 font-mono text-xs">
                {navLinks.map((link) => (
                  <a
                    href={link.href}
                    class="text-text-muted hover:text-text-primary transition-colors"
                    key={link.href}
                  >
                    &gt; {link.label}
                  </a>
                ))}
              </div>
            </div>
            <!-- Col 3: External -->
            <div>
              <p class="font-mono text-xs text-text-muted uppercase tracking-widest mb-3">External</p>
              <div class="flex flex-col gap-1.5 font-mono text-xs">
                <a href="https://github.com/neoneye" target="_blank" rel="noopener"
                   class="text-text-muted hover:text-node-blue transition-colors">github.com/neoneye</a>
                <a href="https://github.com/VoynichLabs" target="_blank" rel="noopener"
                   class="text-text-muted hover:text-node-blue transition-colors">github.com/VoynichLabs</a>
                <a href="https://loda-lang.org" target="_blank" rel="noopener"
                   class="text-text-muted hover:text-edge-green transition-colors">loda-lang.org</a>
                <a href="https://markbarney.net" target="_blank" rel="noopener"
                   class="text-text-muted hover:text-node-blue transition-colors">markbarney.net</a>
              </div>
            </div>
          </div>
          <div class="mt-10 pt-6 border-t border-border flex items-center justify-between text-xs font-mono text-text-muted">
            <span>&copy; {new Date().getFullYear()} VoynichLabs</span>
            <span class="text-border">Simon Strandgaard &middot; <a href="https://markbarney.net" target="_blank" rel="noopener" class="hover:text-text-muted transition-colors">Mark Barney</a></span>
          </div>
        </div>
      </footer>
    )}
  </body>
</html>
