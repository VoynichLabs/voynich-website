---
// Author: Bubba (claude-sonnet-4-20250514) for VoynichLabs
// Date: 2026-03-21
// PURPOSE: Full reading experience for the autonovel — a cephalopod sci-fi novel
//          generated by the autonovel pipeline. Renders all 21 chapters with a
//          proper dark reading aesthetic: deep ocean bioluminescence palette,
//          EB Garamond serif body text, comfortable 65ch measure. Includes hero
//          with premise, TOC with word counts, prev/next chapter navigation,
//          and anchor-linked chapter sections. No mocks — real content from the
//          pre-built JSON data file.
// SRP/DRY check: Pass — single page handles layout + content rendering.
//                Chapter text processing (markdown → HTML) is a pure helper function.
import Base from '../layouts/Base.astro';
import chaptersData from '../data/autonovel-chapters.json';

// ── markdown → HTML (no deps — handles the subset used in these chapters) ──────
// Converts the markdown text in each chapter to safe HTML for inline rendering.
// Handles: headings (# ##), bold, italic, em-dashes, horizontal rules, paragraphs.
// Does NOT use a markdown library to avoid adding a dependency; the subset is
// small enough to handle with targeted replacements.
function mdToHtml(text: string): string {
  const lines = text.split('\n');
  const htmlParts: string[] = [];
  let inParagraph = false;

  const closeP = () => {
    if (inParagraph) { htmlParts.push('</p>'); inParagraph = false; }
  };

  const inlineFormat = (s: string) => s
    // bold
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    // italic (but not the em-dash triple-dot sequences)
    .replace(/\*([^*\n]+?)\*/g, '<em>$1</em>')
    // smart em-dash: " -- " and "—" → proper em dash
    .replace(/\s*—\s*/g, '\u2009\u2014\u2009')
    // Unicode already handled; ensure escaped chars render
    ;

  for (let i = 0; i < lines.length; i++) {
    const raw = lines[i];
    const line = raw.trimEnd();

    // Skip the top-level # title (we render the chapter heading separately)
    if (/^#\s+Chapter/.test(line) || /^#\s+CHAPTER/.test(line) || /^###\s+Chapter/.test(line)) {
      closeP();
      continue;
    }

    // ## Subheading — POV section header (e.g. "## Raj", "## Irina")
    if (/^##\s+/.test(line)) {
      closeP();
      const heading = inlineFormat(line.replace(/^##\s+/, ''));
      htmlParts.push(`<h3 class="pov-heading">${heading}</h3>`);
      continue;
    }

    // Horizontal rule
    if (/^---+$/.test(line.trim())) {
      closeP();
      htmlParts.push('<hr class="section-break" />');
      continue;
    }

    // Blank line → close paragraph
    if (line.trim() === '') {
      closeP();
      continue;
    }

    // Normal line — append to current paragraph or open a new one
    const formatted = inlineFormat(line.trim());
    if (!inParagraph) {
      htmlParts.push('<p>');
      inParagraph = true;
    } else {
      htmlParts.push(' ');
    }
    htmlParts.push(formatted);
  }
  closeP();
  return htmlParts.join('');
}

// Normalize chapter titles for display (strip the "Chapter N:" prefix if present)
function chapterTitle(ch: { num: number; title: string }): string {
  // Some late chapters have no clean title — provide fallbacks
  const titleMap: Record<number, string> = {
    18: 'The Bridge',
    19: '0.3̅ Alone',
    20: 'The Reveal',
    21: 'Yield',
  };
  if (titleMap[ch.num]) return titleMap[ch.num];
  // Strip leading "Chapter N: " or "CHAPTER N: "
  return ch.title
    .replace(/^#+\s+/g, '')          // strip markdown heading markers
    .replace(/^CHAPTER\s+\d+[:\s—]*/i, '')
    .replace(/^Chapter\s+\d+[:\s—]*/i, '')
    .trim() || `Chapter ${ch.num}`;
}

// Total novel word count (from the JSON)
const totalWords = chaptersData.reduce((sum, ch) => sum + ch.text.split(/\s+/).length, 0);
---

<Base
  title="autonovel — a cephalopod science fiction"
  description="A science fiction novel generated by the autonovel pipeline. Earth is a protected galactic nature reserve. A rogue cephalopod scientist abducts humans, conducting illegal experiments to prove they're more than vermin."
  ogType="article"
>

  <!-- ── FONTS: EB Garamond for body text ───────────────────────────────── -->
  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&display=swap');

    /* Reading body typography */
    .novel-body {
      font-family: 'EB Garamond', Georgia, 'Times New Roman', serif;
      font-size: 1.175rem;
      line-height: 1.82;
      color: #c8ccd8;
      max-width: 65ch;
      margin: 0 auto;
    }
    .novel-body p {
      margin: 0 0 1.1em 0;
      text-indent: 1.5em;
    }
    /* Don't indent first paragraph after heading or hr */
    .novel-body h3 + p,
    .novel-body hr + p,
    .novel-body p:first-child {
      text-indent: 0;
    }
    .novel-body em {
      font-style: italic;
      color: #d8dce8;
    }
    .novel-body strong {
      font-weight: 600;
      color: #e8eaf0;
    }
    /* POV section header (## Raj, ## Irina, ## Xi Pei) */
    .pov-heading {
      font-family: 'JetBrains Mono', 'Fira Code', monospace;
      font-size: 0.75rem;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #52e0c4; /* bioluminescent teal */
      margin: 2.5rem 0 1.2rem 0;
      padding-bottom: 0.4rem;
      border-bottom: 1px solid rgba(82, 224, 196, 0.2);
    }
    /* Section break rule */
    .section-break {
      border: none;
      border-top: 1px solid rgba(82, 224, 196, 0.15);
      margin: 2rem auto;
      width: 30%;
    }
    /* Scrollspy: highlight active TOC item */
    .toc-item.active a {
      color: #52e0c4;
    }
    /* Bioluminescent glow on chapter titles */
    .chapter-num {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: #52e0c4;
      opacity: 0.7;
    }
    /* Deep water gradient hero */
    .hero-gradient {
      background: radial-gradient(ellipse at 50% 0%, rgba(0,64,80,0.6) 0%, rgba(8,12,20,0) 70%),
                  linear-gradient(180deg, #04080f 0%, #060d14 60%, #0c0c14 100%);
    }
    /* Subtle bioluminescent shimmer on nav dots */
    @keyframes biolume {
      0%, 100% { opacity: 0.4; }
      50% { opacity: 1; }
    }
    .biolume { animation: biolume 3s ease-in-out infinite; }
  </style>

  <!-- ── HERO ──────────────────────────────────────────────────────────── -->
  <section class="hero-gradient min-h-[72vh] flex flex-col items-center justify-center px-6 pt-8 pb-16 text-center relative overflow-hidden">
    <!-- Subtle deep water texture: scattered bioluminescent dots -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
      {Array.from({ length: 28 }).map((_, i) => (
        <div
          class="absolute rounded-full biolume"
          style={`
            width: ${1 + (i % 4) * 0.5}px;
            height: ${1 + (i % 4) * 0.5}px;
            left: ${((i * 37) % 97)}%;
            top: ${((i * 53) % 89)}%;
            background: ${i % 3 === 0 ? '#39FF14' : i % 3 === 1 ? '#52e0c4' : '#00bfff'};
            animation-delay: ${(i * 0.4).toFixed(1)}s;
            opacity: 0.35;
          `}
        />
      ))}
    </div>

    <!-- Title lockup -->
    <p class="font-mono text-xs tracking-[0.35em] text-teal-400 uppercase mb-6 opacity-70">
      VoynichLabs&nbsp;/&nbsp;autonovel
    </p>
    <h1 class="text-5xl md:text-7xl font-serif tracking-tight text-slate-100 mb-4" style="font-family: 'EB Garamond', Georgia, serif; font-weight: 500;">
      The Specimens
    </h1>
    <p class="text-lg md:text-xl font-mono text-teal-300 mb-2 tracking-wide" style="letter-spacing: 0.04em;">
      0.3̅ + 2(#39FF14)ω
    </p>
    <p class="text-base text-slate-400 mb-8 font-mono text-xs tracking-widest uppercase">
      A cephalopod science fiction
    </p>

    <!-- Premise -->
    <div class="max-w-2xl text-left bg-slate-900/60 border border-teal-900/40 rounded-sm p-6 md:p-8 backdrop-blur-sm">
      <p class="font-serif text-slate-300 leading-relaxed text-lg mb-4" style="font-family: 'EB Garamond', Georgia, serif;">
        Earth is a nature preserve. Humans are vermin. Cephalopods are the dominant civilization, and they have been for longer than human language has existed.
      </p>
      <p class="font-serif text-slate-400 leading-relaxed mb-4" style="font-family: 'EB Garamond', Georgia, serif;">
        0.3̅ is a rogue cephalopod scientist who disagrees. She abducts six humans and implants them with jellyfish bio-organisms that terraform their nervous systems from the inside — growing chitinous nodes at the temples that interface with the cephalopod telepathic network. Her thesis: these animals are more than food. Some subjects sync. Some are fried. She tracks outcomes with scientific detachment.
      </p>
      <p class="font-serif text-slate-400 leading-relaxed mb-4" style="font-family: 'EB Garamond', Georgia, serif;">
        The horror is not the implant. The horror is what comes after. The squids dress their elevated humans in bio-suits — little squid-adjacent outfits so the subjects can navigate a world not built for them. The way you put a sweater on a Yorkshire terrier. The affection is genuine. So is the ownership.
      </p>
      <p class="font-serif text-slate-400 leading-relaxed mb-4" style="font-family: 'EB Garamond', Georgia, serif;">
        Three POV humans. One adapts too well and stops wanting to leave. One reverse-engineers everything, running forensic analysis on her own transformation. One holds the answer the squids actually need — and stays silent, watching, waiting for the right moment to make it worth something.
      </p>
      <p class="font-serif text-slate-400 leading-relaxed" style="font-family: 'EB Garamond', Georgia, serif;">
        This is not a story about humans. It's about a cephalopod civilization that humans can barely perceive. The dystopia doesn't know it's a dystopia. The elevation process isn't cruelty.
      </p>
      <p class="font-serif text-slate-300 leading-relaxed mt-4 text-base italic" style="font-family: 'EB Garamond', Georgia, serif; color: #94a3b8;">
        That's the horror.
      </p>
    </div>

    <!-- Stats row -->
    <div class="flex gap-8 mt-10 font-mono text-xs text-slate-500 tracking-widest">
      <span><span class="text-teal-400">{chaptersData.length}</span>&nbsp;chapters</span>
      <span><span class="text-teal-400">{totalWords.toLocaleString()}</span>&nbsp;words</span>
      <span><span class="text-teal-400">3</span>&nbsp;POV humans</span>
      <span><span class="text-teal-400">1</span>&nbsp;rogue cephalopod</span>
    </div>

    <!-- CTA: jump to reading -->
    <a
      href="#toc"
      class="mt-10 inline-flex items-center gap-2 px-6 py-2.5 border border-teal-700/50 text-teal-400 font-mono text-xs tracking-widest uppercase hover:bg-teal-900/20 transition-colors duration-200"
    >
      begin reading ↓
    </a>
  </section>

  <!-- ── TABLE OF CONTENTS ──────────────────────────────────────────────── -->
  <section id="toc" class="bg-bg-primary py-20 px-6">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-mono text-xs tracking-[0.3em] text-slate-500 uppercase mb-8">Table of Contents</h2>

      <ol class="space-y-1">
        {chaptersData.map((ch) => {
          const words = ch.text.split(/\s+/).length;
          const title = chapterTitle(ch);
          return (
            <li class="toc-item group">
              <a
                href={`#chapter-${ch.num}`}
                class="flex items-baseline justify-between gap-4 py-2 px-3 -mx-3 hover:bg-slate-800/40 transition-colors duration-150 group"
              >
                <span class="flex items-baseline gap-4 min-w-0">
                  <span class="font-mono text-xs text-slate-600 shrink-0 w-6 text-right">{ch.num}</span>
                  <span class="font-serif text-slate-300 group-hover:text-teal-300 transition-colors duration-150 truncate" style="font-family: 'EB Garamond', Georgia, serif; font-size: 1.1rem;">
                    {title.trim() || `Chapter ${ch.num}`}
                  </span>
                </span>
                <span class="font-mono text-xs text-slate-600 shrink-0 tabular-nums">{words.toLocaleString()} w</span>
              </a>
            </li>
          );
        })}
      </ol>

      <!-- Word count total -->
      <div class="mt-8 pt-6 border-t border-slate-800 flex justify-between font-mono text-xs text-slate-600">
        <span>total</span>
        <span>{totalWords.toLocaleString()} words</span>
      </div>
    </div>
  </section>

  <!-- ── CHAPTER TEXT ───────────────────────────────────────────────────── -->
  {chaptersData.map((ch, idx) => {
    const words = ch.text.split(/\s+/).length;
    const title = chapterTitle(ch);
    const prevCh = idx > 0 ? chaptersData[idx - 1] : null;
    const nextCh = idx < chaptersData.length - 1 ? chaptersData[idx + 1] : null;
    const htmlContent = mdToHtml(ch.text);

    return (
      <article
        id={`chapter-${ch.num}`}
        class="bg-bg-primary py-20 px-6 border-t border-slate-800/60"
      >
        <div class="max-w-3xl mx-auto">

          <!-- Chapter header -->
          <header class="mb-12 pb-8 border-b border-teal-900/30">
            <p class="chapter-num mb-3">Chapter {ch.num}</p>
            <h2 class="font-serif text-slate-100 mb-3" style="font-family: 'EB Garamond', Georgia, serif; font-size: 2.25rem; font-weight: 500; line-height: 1.2;">
              {title.trim() || `Chapter ${ch.num}`}
            </h2>
            <p class="font-mono text-xs text-slate-600">{words.toLocaleString()} words</p>
          </header>

          <!-- Chapter body — rendered markdown -->
          <div class="novel-body" set:html={htmlContent} />

          <!-- Chapter navigation -->
          <nav class="mt-16 pt-8 border-t border-slate-800/60 flex items-center justify-between gap-4 font-mono text-xs">
            {prevCh ? (
              <a
                href={`#chapter-${prevCh.num}`}
                class="flex items-center gap-2 text-slate-500 hover:text-teal-400 transition-colors duration-150"
              >
                ← <span class="hidden sm:inline">{chapterTitle(prevCh) || `Chapter ${prevCh.num}`}</span>
                <span class="sm:hidden">prev</span>
              </a>
            ) : <span />}

            <a
              href="#toc"
              class="text-slate-600 hover:text-teal-400 transition-colors duration-150 tracking-widest uppercase text-[0.6rem]"
            >
              ↑ contents
            </a>

            {nextCh ? (
              <a
                href={`#chapter-${nextCh.num}`}
                class="flex items-center gap-2 text-slate-500 hover:text-teal-400 transition-colors duration-150"
              >
                <span class="hidden sm:inline">{chapterTitle(nextCh) || `Chapter ${nextCh.num}`}</span>
                <span class="sm:hidden">next</span>
                →
              </a>
            ) : <span />}
          </nav>
        </div>
      </article>
    );
  })}

  <!-- ── END OF NOVEL FOOTER ────────────────────────────────────────────── -->
  <section class="hero-gradient py-16 px-6 text-center border-t border-teal-900/30">
    <p class="font-mono text-xs tracking-[0.3em] text-teal-400 uppercase mb-4 opacity-60">End of current draft</p>
    <p class="font-serif text-slate-400 max-w-lg mx-auto leading-relaxed" style="font-family: 'EB Garamond', Georgia, serif;">
      <em>The Specimens</em> is an ongoing work generated by the VoynichLabs autonovel pipeline.
      21 chapters, {totalWords.toLocaleString()} words. The story continues.
    </p>
    <a
      href="https://github.com/VoynichLabs/autonovel"
      target="_blank"
      rel="noopener"
      class="mt-8 inline-flex items-center gap-2 font-mono text-xs text-slate-500 hover:text-teal-400 transition-colors duration-200 tracking-widest"
    >
      github.com/VoynichLabs/autonovel →
    </a>
  </section>

</Base>
