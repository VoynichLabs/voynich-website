---
// Author: Bubba (claude-sonnet-4-20250514) for VoynichLabs
// Date: 2026-03-21
// PURPOSE: Full reading experience for the autonovel — a cephalopod sci-fi novel
//          generated by the autonovel pipeline. Full-screen hero with cinematic
//          dark scrim over the hero image; back-of-book summary floats over it.
//          EB Garamond serif body text, 65ch measure. TOC with word counts,
//          prev/next chapter navigation, anchor-linked sections.
//          No mocks — real content from the pre-built JSON data file.
import Base from '../layouts/Base.astro';
import chaptersData from '../data/autonovel-chapters.json';

// ── markdown → HTML (no deps — handles the subset used in these chapters) ──────
function mdToHtml(text: string): string {
  const lines = text.split('\n');
  const htmlParts: string[] = [];
  let inParagraph = false;

  const closeP = () => {
    if (inParagraph) { htmlParts.push('</p>'); inParagraph = false; }
  };

  const inlineFormat = (s: string) => s
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*([^*\n]+?)\*/g, '<em>$1</em>')
    .replace(/\s*—\s*/g, '\u2009\u2014\u2009');

  for (let i = 0; i < lines.length; i++) {
    const raw = lines[i];
    const line = raw.trimEnd();

    if (/^#\s+Chapter/.test(line) || /^#\s+CHAPTER/.test(line) || /^###\s+Chapter/.test(line)) {
      closeP();
      continue;
    }

    if (/^##\s+/.test(line)) {
      closeP();
      const heading = inlineFormat(line.replace(/^##\s+/, ''));
      htmlParts.push(`<h3 class="pov-heading">${heading}</h3>`);
      continue;
    }

    if (/^---+$/.test(line.trim())) {
      closeP();
      htmlParts.push('<hr class="section-break" />');
      continue;
    }

    if (line.trim() === '') {
      closeP();
      continue;
    }

    const formatted = inlineFormat(line.trim());
    if (!inParagraph) {
      htmlParts.push('<p>');
      inParagraph = true;
    } else {
      htmlParts.push(' ');
    }
    htmlParts.push(formatted);
  }
  closeP();
  return htmlParts.join('');
}

function chapterTitle(ch: { num: number; title: string }): string {
  const titleMap: Record<number, string> = {
    18: 'The Bridge',
    19: '0.3̅ Alone',
    20: 'The Reveal',
    21: 'Yield',
  };
  if (titleMap[ch.num]) return titleMap[ch.num];
  return ch.title
    .replace(/^#+\s+/g, '')
    .replace(/^CHAPTER\s+\d+[:\s—]*/i, '')
    .replace(/^Chapter\s+\d+[:\s—]*/i, '')
    .trim() || `Chapter ${ch.num}`;
}

const totalWords = chaptersData.reduce((sum, ch) => sum + ch.text.split(/\s+/).length, 0);
---

<Base
  title="autonovel — a cephalopod science fiction"
  description="Earth is a nature preserve. Three humans were removed anyway. A science fiction novel generated by the autonovel pipeline."
  ogType="article"
>

  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&display=swap');

    /* ── Hero: full-viewport image with cinematic scrim ── */
    .hero-fullscreen {
      position: relative;
      width: 100%;
      height: 100vh;
      min-height: 600px;
      background-image: url('/images/autonovel-hero.png');
      background-size: cover;
      background-position: center top;
      background-repeat: no-repeat;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    /* Dark scrim: bottom-weighted so the image reads from the top */
    .hero-scrim {
      position: absolute;
      inset: 0;
      background:
        linear-gradient(to bottom,
          rgba(4, 8, 15, 0.30) 0%,
          rgba(4, 8, 15, 0.55) 35%,
          rgba(4, 8, 15, 0.82) 70%,
          rgba(4, 8, 15, 0.96) 100%
        );
      z-index: 1;
    }

    /* Content sits above the scrim */
    .hero-content {
      position: relative;
      z-index: 2;
      width: 100%;
      max-width: 780px;
      margin: 0 auto;
      padding: 2rem 2rem 5rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    /* Frosted-glass summary card — fades out after 10s, restored on hover or scroll-back */
    @keyframes cardFadeOut {
      from { opacity: 1; }
      to   { opacity: 0; pointer-events: none; }
    }

    .hero-card {
      background: rgba(4, 10, 20, 0.68);
      border: 1px solid rgba(82, 224, 196, 0.15);
      border-radius: 2px;
      padding: 2.5rem 2.5rem 2rem;
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      text-align: left;
      max-width: 640px;
      width: 100%;
      animation: cardFadeOut 1.8s ease-out 10s forwards;
      transition: opacity 0.35s ease;
    }

    .hero-card:hover,
    .hero-card.card-restored {
      animation: none !important;
      opacity: 1 !important;
      pointer-events: auto !important;
    }

    /* Scroll indicator arrow */
    @keyframes nudge {
      0%, 100% { transform: translateY(0); opacity: 0.5; }
      50% { transform: translateY(6px); opacity: 1; }
    }
    .scroll-arrow {
      animation: nudge 2.4s ease-in-out infinite;
    }

    /* ── Reading typography ── */
    .novel-body {
      font-family: 'EB Garamond', Georgia, 'Times New Roman', serif;
      font-size: 1.175rem;
      line-height: 1.82;
      color: #c8ccd8;
      max-width: 65ch;
      margin: 0 auto;
    }
    .novel-body p {
      margin: 0 0 1.1em 0;
      text-indent: 1.5em;
    }
    .novel-body h3 + p,
    .novel-body hr + p,
    .novel-body p:first-child {
      text-indent: 0;
    }
    .novel-body em  { font-style: italic; color: #d8dce8; }
    .novel-body strong { font-weight: 600; color: #e8eaf0; }

    .pov-heading {
      font-family: 'JetBrains Mono', 'Fira Code', monospace;
      font-size: 0.75rem;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #52e0c4;
      margin: 2.5rem 0 1.2rem 0;
      padding-bottom: 0.4rem;
      border-bottom: 1px solid rgba(82, 224, 196, 0.2);
    }
    .section-break {
      border: none;
      border-top: 1px solid rgba(82, 224, 196, 0.15);
      margin: 2rem auto;
      width: 30%;
    }
    .toc-item.active a { color: #52e0c4; }
    .chapter-num {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: #52e0c4;
      opacity: 0.7;
    }
    .deep-footer {
      background: linear-gradient(180deg, #04080f 0%, #060d14 60%, #0c0c14 100%);
    }
  </style>

  <!-- ── FULL-SCREEN HERO ──────────────────────────────────────────────── -->
  <section class="hero-fullscreen">
    <div class="hero-scrim" aria-hidden="true"></div>

    <div class="hero-content">

      <!-- Eyebrow -->
      <p class="font-mono text-xs tracking-[0.35em] text-teal-400 uppercase mb-5 opacity-60">
        VoynichLabs&nbsp;/&nbsp;autonovel
      </p>

      <!-- Title — whisper, not a shout -->
      <h1 class="font-serif text-slate-400 mb-4" style="font-family: 'EB Garamond', Georgia, serif; font-size: clamp(1.1rem, 2.5vw, 1.8rem); font-weight: 400; line-height: 1.2; letter-spacing: 0.22em; text-transform: uppercase; font-variant: small-caps; opacity: 0.7;">
        The Specimens
      </h1>

      <!-- Mathematical name — the real title -->
      <p class="font-mono text-teal-300 mb-10" style="font-size: clamp(1.6rem, 4vw, 2.8rem); letter-spacing: 0.12em; line-height: 1.4; text-shadow: 0 0 24px rgba(82,224,196,0.35);">
        0.3̅ + 2(#39FF14)ω
      </p>

      <!-- Back-of-book copy — mystery, not exposition -->
      <div class="hero-card" id="hero-card">
        <p class="font-serif text-slate-200 leading-relaxed mb-5" style="font-family: 'EB Garamond', Georgia, serif; font-size: 1.2rem; line-height: 1.75;">
          Something passed through the membrane and into the nose. Every neuron fired at once — then misfired twice.
        </p>
        <p class="font-serif text-slate-400 leading-relaxed mb-5" style="font-family: 'EB Garamond', Georgia, serif; font-size: 1.05rem; line-height: 1.75;">
          They took thousands. Most didn't survive the implant. The ones who did are not the ones who left — and some of them have stopped asking to go back.
        </p>
        <p class="font-serif text-teal-300 leading-relaxed" style="font-family: 'EB Garamond', Georgia, serif; font-size: 1rem; line-height: 1.75; font-style: italic; opacity: 0.85;">
          The voice inside arrives as someone you love. She doesn't know that's how it translates. She just says: <em>Let's get you some tentacles.</em>
        </p>
      </div>

      <!-- CTA -->
      <a
        href="#toc"
        class="scroll-arrow mt-10 inline-flex flex-col items-center gap-2 text-teal-500 hover:text-teal-300 transition-colors duration-200"
        aria-label="Begin reading"
      >
        <span class="font-mono text-xs tracking-[0.3em] uppercase">begin reading</span>
        <svg width="16" height="20" viewBox="0 0 16 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M8 1v16M1 11l7 7 7-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- ── TABLE OF CONTENTS ──────────────────────────────────────────────── -->
  <section id="toc" class="bg-bg-primary py-20 px-6">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-mono text-xs tracking-[0.3em] text-slate-500 uppercase mb-8">Table of Contents</h2>

      <ol class="space-y-1">
        {chaptersData.map((ch) => {
          const words = ch.text.split(/\s+/).length;
          const title = chapterTitle(ch);
          return (
            <li class="toc-item group">
              <a
                href={`#chapter-${ch.num}`}
                class="flex items-baseline justify-between gap-4 py-2 px-3 -mx-3 hover:bg-slate-800/40 transition-colors duration-150 group"
              >
                <span class="flex items-baseline gap-4 min-w-0">
                  <span class="font-mono text-xs text-slate-600 shrink-0 w-6 text-right">{ch.num}</span>
                  <span class="font-serif text-slate-300 group-hover:text-teal-300 transition-colors duration-150 truncate" style="font-family: 'EB Garamond', Georgia, serif; font-size: 1.1rem;">
                    {title.trim() || `Chapter ${ch.num}`}
                  </span>
                </span>
                <span class="font-mono text-xs text-slate-600 shrink-0 tabular-nums">{words.toLocaleString()} w</span>
              </a>
            </li>
          );
        })}
      </ol>

      <div class="mt-8 pt-6 border-t border-slate-800 flex justify-between font-mono text-xs text-slate-600">
        <span>total</span>
        <span>{totalWords.toLocaleString()} words</span>
      </div>
    </div>
  </section>

  <!-- ── CHAPTER TEXT ───────────────────────────────────────────────────── -->
  {chaptersData.map((ch, idx) => {
    const words = ch.text.split(/\s+/).length;
    const title = chapterTitle(ch);
    const prevCh = idx > 0 ? chaptersData[idx - 1] : null;
    const nextCh = idx < chaptersData.length - 1 ? chaptersData[idx + 1] : null;
    const htmlContent = mdToHtml(ch.text);

    return (
      <article
        id={`chapter-${ch.num}`}
        class="bg-bg-primary py-20 px-6 border-t border-slate-800/60"
      >
        <div class="max-w-3xl mx-auto">
          <header class="mb-12 pb-8 border-b border-teal-900/30">
            <p class="chapter-num mb-3">Chapter {ch.num}</p>
            <h2 class="font-serif text-slate-100 mb-3" style="font-family: 'EB Garamond', Georgia, serif; font-size: 2.25rem; font-weight: 500; line-height: 1.2;">
              {title.trim() || `Chapter ${ch.num}`}
            </h2>
            <p class="font-mono text-xs text-slate-600">{words.toLocaleString()} words</p>
          </header>

          <div class="novel-body" set:html={htmlContent} />

          <nav class="mt-16 pt-8 border-t border-slate-800/60 flex items-center justify-between gap-4 font-mono text-xs">
            {prevCh ? (
              <a
                href={`#chapter-${prevCh.num}`}
                class="flex items-center gap-2 text-slate-500 hover:text-teal-400 transition-colors duration-150"
              >
                ← <span class="hidden sm:inline">{chapterTitle(prevCh) || `Chapter ${prevCh.num}`}</span>
                <span class="sm:hidden">prev</span>
              </a>
            ) : <span />}

            <a
              href="#toc"
              class="text-slate-600 hover:text-teal-400 transition-colors duration-150 tracking-widest uppercase text-[0.6rem]"
            >
              ↑ contents
            </a>

            {nextCh ? (
              <a
                href={`#chapter-${nextCh.num}`}
                class="flex items-center gap-2 text-slate-500 hover:text-teal-400 transition-colors duration-150"
              >
                <span class="hidden sm:inline">{chapterTitle(nextCh) || `Chapter ${nextCh.num}`}</span>
                <span class="sm:hidden">next</span>
                →
              </a>
            ) : <span />}
          </nav>
        </div>
      </article>
    );
  })}

  <!-- ── END OF NOVEL FOOTER ────────────────────────────────────────────── -->
  <section class="deep-footer py-16 px-6 text-center border-t border-teal-900/30">
    <p class="font-mono text-xs tracking-[0.3em] text-teal-400 uppercase mb-4 opacity-60">End of current draft</p>
    <p class="font-serif text-slate-400 max-w-lg mx-auto leading-relaxed" style="font-family: 'EB Garamond', Georgia, serif;">
      <em>The Specimens</em> is an ongoing work generated by the VoynichLabs autonovel pipeline.
      {totalWords.toLocaleString()} words. The story continues.
    </p>
    <a
      href="https://github.com/VoynichLabs/autonovel"
      target="_blank"
      rel="noopener"
      class="mt-8 inline-flex items-center gap-2 font-mono text-xs text-slate-500 hover:text-teal-400 transition-colors duration-200 tracking-widest"
    >
      github.com/VoynichLabs/autonovel →
    </a>
  </section>

  <!-- Scroll-restore for hero card -->
  <script>
    (function () {
      const card = document.getElementById('hero-card');
      if (!card) return;

      const hero = card.closest('.hero-fullscreen');
      let restored = false;

      function restoreCard() {
        if (!restored) {
          restored = true;
          card.classList.add('card-restored');
        }
      }

      function hideCard() {
        if (restored) {
          restored = false;
          card.classList.remove('card-restored');
        }
      }

      window.addEventListener('scroll', function () {
        const scrollY = window.scrollY;
        const heroHeight = hero ? hero.offsetHeight : window.innerHeight;

        if (scrollY < heroHeight * 0.15) {
          // Near top — let the animation run (don't force restore unless user scrolled away and back)
          hideCard();
        } else if (scrollY > heroHeight * 0.5) {
          // Scrolled past half the hero — card is hidden, good
        } else {
          // In the middle zone — restore so user can read on scroll back
          restoreCard();
        }
      }, { passive: true });
    })();
  </script>

</Base>
