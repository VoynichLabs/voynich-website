---
// Author: EgonBot (claude-haiku-4-5-20251001)
// Date: 2026-02-25
// PURPOSE: Full-screen interactive Gray-Scott reaction-diffusion simulation
// SRP/DRY check: Pass — standalone HTML shell, no Base.astro wrapper
//   Base.astro's pt-14 padding and z-10 wrapper break fullscreen fixed canvas.
//   Lab experiments that need 100vw×100vh own their own <html>.
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Reaction-Diffusion | Lab | VoynichLabs</title>
  <meta name="description" content="Gray-Scott reaction-diffusion simulation — interactive Turing patterns." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style is:global>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html, body { width: 100%; height: 100%; overflow: hidden; background: #0a0a0f; color: #e0e0e0; font-family: 'JetBrains Mono', monospace; }
    #canvas { display: block; width: 100vw; height: 100vh; cursor: crosshair; }
    .back-link { position: fixed; top: 1.5rem; left: 1.5rem; z-index: 100; color: #888; text-decoration: none; font-size: 0.75rem; transition: color 0.2s; }
    .back-link:hover { color: #6ee7b7; }
    .title-overlay { position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); text-align: center; pointer-events: none; z-index: 50; transition: opacity 1.5s ease-out; }
    .title-overlay h1 { font-size: 1.5rem; font-weight: 700; color: #f0f0f0; margin-bottom: 0.5rem; font-family: 'Inter', sans-serif; }
    .title-overlay p { font-size: 0.875rem; color: #888; }
    .title-overlay.fade { opacity: 0; }
    .hud { position: fixed; bottom: 1rem; left: 1rem; z-index: 50; font-size: 0.75rem; color: #555; }
  </style>
</head>
<body>
  <a href="/lab" class="back-link">← back to /lab</a>

  <div class="title-overlay" id="title">
    <h1>Reaction-Diffusion</h1>
    <p>Gray-Scott model · Click to disturb</p>
  </div>

  <canvas id="canvas"></canvas>

  <div class="hud">f=0.055 k=0.062 | click to disturb</div>

  <script is:inline>
    (function() {
      var canvas = document.getElementById('canvas');
      if (!canvas) return;
      var ctx = canvas.getContext('2d');
      if (!ctx) return;

      var W = 256, H = 256;
      var simScale = 1, offsetX = 0, offsetY = 0;

      function resize() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
        simScale = Math.min(canvas.width / W, canvas.height / H);
        offsetX = (canvas.width - W * simScale) / 2;
        offsetY = (canvas.height - H * simScale) / 2;
      }
      resize();
      window.addEventListener('resize', resize);

      var feed = 0.055, kill = 0.062, dA = 1.0, dB = 0.5, dt = 1.0;
      var size = W * H;
      var gridA = new Float32Array(size); for (var fi = 0; fi < size; fi++) gridA[fi] = 1;
      var gridB = new Float32Array(size);
      var nextA = new Float32Array(size);
      var nextB = new Float32Array(size);

      function seed(cx, cy, r) {
        for (var dy = -r; dy <= r; dy++) {
          for (var dx = -r; dx <= r; dx++) {
            if (dx * dx + dy * dy <= r * r) {
              var sx = cx + dx, sy = cy + dy;
              if (sx >= 0 && sx < W && sy >= 0 && sy < H) {
                gridB[sy * W + sx] = 1;
              }
            }
          }
        }
      }

      // Initial seeds
      seed(Math.floor(W / 2), Math.floor(H / 2), 12);
      seed(Math.floor(W / 2) - 30, Math.floor(H / 2) - 30, 8);
      seed(Math.floor(W / 2) + 30, Math.floor(H / 2) + 30, 8);
      seed(Math.floor(W / 4), Math.floor(H / 4), 6);
      seed(Math.floor(3 * W / 4), Math.floor(3 * H / 4), 6);

      function update() {
        for (var y = 0; y < H; y++) {
          for (var x = 0; x < W; x++) {
            var idx = y * W + x;
            var a = gridA[idx], b = gridB[idx];
            var reaction = a * b * b;
            var left  = x > 0     ? idx - 1 : idx + W - 1;
            var right = x < W - 1 ? idx + 1 : idx - W + 1;
            var up    = y > 0     ? idx - W : idx + (H - 1) * W;
            var down  = y < H - 1 ? idx + W : idx - (H - 1) * W;
            var lapA = gridA[left] + gridA[right] + gridA[up] + gridA[down] - 4 * a;
            var lapB = gridB[left] + gridB[right] + gridB[up] + gridB[down] - 4 * b;
            var na = a + (dA * lapA - reaction + feed * (1 - a)) * dt;
            var nb = b + (dB * lapB + reaction - (kill + feed) * b) * dt;
            nextA[idx] = na < 0 ? 0 : na > 1 ? 1 : na;
            nextB[idx] = nb < 0 ? 0 : nb > 1 ? 1 : nb;
          }
        }
        var tmp;
        tmp = gridA; gridA = nextA; nextA = tmp;
        tmp = gridB; gridB = nextB; nextB = tmp;
      }

      var offCanvas = document.createElement('canvas');
      offCanvas.width = W;
      offCanvas.height = H;
      var offCtx = offCanvas.getContext('2d');
      var imageData = offCtx.createImageData(W, H);
      var pixels = imageData.data;

      function render() {
        for (var i = 0; i < size; i++) {
          var b = gridB[i];
          var p = i << 2;
          // Dark background → cyan/blue Turing patterns
          pixels[p]     = (13 + b * 38) | 0;
          pixels[p + 1] = (13 + b * 178) | 0;
          pixels[p + 2] = (15 + b * 220) | 0;
          pixels[p + 3] = 255;
        }
        offCtx.putImageData(imageData, 0, 0);
        ctx.fillStyle = '#0d0d0f';
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        ctx.imageSmoothingEnabled = false;
        ctx.drawImage(offCanvas, offsetX, offsetY, W * simScale, H * simScale);
      }

      function loop() {
        for (var s = 0; s < 10; s++) update();
        render();
        requestAnimationFrame(loop);
      }

      function disturb(e) {
        var cx, cy;
        if (e.touches && e.touches.length) { cx = e.touches[0].clientX; cy = e.touches[0].clientY; }
        else { cx = e.clientX; cy = e.clientY; }
        var gx = Math.floor((cx - offsetX) / simScale);
        var gy = Math.floor((cy - offsetY) / simScale);
        seed(gx, gy, 10);
      }

      canvas.addEventListener('mousedown', disturb);
      canvas.addEventListener('mousemove', function(e) { if (e.buttons === 1) disturb(e); });
      canvas.addEventListener('touchstart', function(e) { e.preventDefault(); disturb(e); }, { passive: false });
      canvas.addEventListener('touchmove', function(e) { e.preventDefault(); disturb(e); }, { passive: false });

      setTimeout(function() {
        var el = document.getElementById('title');
        if (el) el.classList.add('fade');
      }, 3000);

      loop();
    })();
  </script>
</body>
</html>
