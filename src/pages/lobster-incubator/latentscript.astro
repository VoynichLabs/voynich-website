---
// Author: Bubba (OpenClaw)
// Date: 2026-03-03
// PURPOSE: Customer-facing overview + playground for LATENTSCRIPT v0.1
// MOVED from /docs/latentscript — this is a concept/proposal, not a live product.
// Removed from main nav. Lives in the incubator now.
import Base from '../../layouts/Base.astro';

const examples = {
  shift: `set max_norm = 15.0;
set max_shift_alpha = 2.0;
set max_decode_tokens = 64;

let p : prompt = "Write an email to my manager about schedule changes.";
let v = encode(p, encoder="emb:email-style", normalize=true) @space("emb:email-style");

let formal_dir = encode("more formal and concise", encoder="emb:email-style") @space("emb:email-style");
let v2 = shift(v, formal_dir, alpha=1.2);

constraint bounded : norm(v2) <= 15.0;

let out = decode(v2, decoder="llm:text", temperature=0.4, max_tokens=64);
emit out as "text";`,

  orthogonalize: `set max_norm = 25.0;

let base = encode("A helpful assistant response", encoder="act:gpt:layer12") @space("act:gpt:layer12");
let fun  = encode("more playful tone", encoder="act:gpt:layer12") @space("act:gpt:layer12");
let safe = encode("avoid personal data", encoder="act:gpt:layer12") @space("act:gpt:layer12");

let mixed = mix(base, fun, t=0.35);
let cleaned = orthogonalize(mixed, against=safe);

constraint keep_norm : norm(cleaned) <= 25.0;
constraint keep_away : abs(dot(cleaned, safe)) <= 1e-4;

emit cleaned as "json";`,

  project: `// basis columns represent a learned subspace (e.g., SAE features)
let basis = load_basis("run42_layer10_basis") ; // runtime extension
let v = encode("Write like Hemingway", encoder="act:gpt:layer10") @space("act:gpt:layer10");

let v_proj = project(v, onto=basis, mode="subspace");
constraint bounded : norm(v_proj) <= 10.0;
emit v_proj as "json";`,
} as const;
