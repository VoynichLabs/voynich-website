  <script type="module" is:inline>
    const EXAMPLES = (${JSON.stringify(examples)});

    const editor = document.getElementById('ls-editor');
    const validationEl = document.getElementById('ls-validation');
    const manifestEl = document.getElementById('ls-manifest');
    const runBtn = document.getElementById('ls-run');
    const resetBtn = document.getElementById('ls-reset');

    let currentExample = 'shift';

    function setActiveTab(name) {
      currentExample = name;
      document.querySelectorAll('.ls-tab').forEach((btn) => {
        const isActive = btn.dataset.example === name;
        btn.className = `ls-tab px-3 py-1.5 rounded-lg font-mono text-xs border border-slate-700 transition-colors ${isActive ? 'bg-slate-950/40 text-slate-200' : 'bg-slate-950/20 text-slate-300 hover:text-slate-100'}`;
      });
      editor.value = EXAMPLES[name] || '';
      validationEl.textContent = 'Ready.';
      manifestEl.textContent = '';
    }

    function stripComments(line) {
      const idx = line.indexOf('//');
      return (idx >= 0 ? line.slice(0, idx) : line).trim();
    }

    function parseAnnotationSpace(stmt) {
      const m = stmt.match(/@space\(\s*"([^"]+)"\s*\)/);
      return m ? m[1] : null;
    }

    function validateLatentScript(program) {
      const errors = [];
      const warnings = [];
      const settings = {};
      const lets = {};
      const constraints = [];
      const emits = [];

      const lines = program.split(/\r?\n/);
      let stmtBuf = '';
      let stmtStartLine = 1;

      function pushStmt(stmt, lineNo) {
        const s = stmt.trim();
        if (!s) return;
        if (!s.endsWith(';')) {
          errors.push({ line: lineNo, msg: 'Statement must end with a semicolon (;)'});
          return;
        }

        // Normalize: remove trailing semicolon.
        const core = s.slice(0, -1).trim();

        // set
        if (core.startsWith('set ')) {
          const m = core.match(/^set\s+([A-Za-z_][A-Za-z0-9_]*)\s*=\s*(.+)$/);
          if (!m) {
            errors.push({ line: lineNo, msg: 'Invalid set statement.'});
            return;
          }
          settings[m[1]] = m[2];
          return;
        }

        // let
        if (core.startsWith('let ')) {
          // let name : type? = expr
          const m = core.match(/^let\s+([A-Za-z_][A-Za-z0-9_]*)(\s*:\s*[^=]+)?\s*=\s*(.+)$/);
          if (!m) {
            errors.push({ line: lineNo, msg: 'Invalid let statement.'});
            return;
          }
          const name = m[1];
          if (lets[name]) {
            errors.push({ line: lineNo, msg: `Redeclaration: ${name}`});
            return;
          }
          const type = (m[2] || '').replace(':', '').trim() || null;
          const expr = m[3].trim();
          lets[name] = { name, type, expr, space: parseAnnotationSpace(core) };
          return;
        }

        // constraint
        if (core.startsWith('constraint ')) {
          const m = core.match(/^constraint\s+(.+)$/);
          if (!m) {
            errors.push({ line: lineNo, msg: 'Invalid constraint statement.'});
            return;
          }
          constraints.push({ line: lineNo, raw: core });
          return;
        }

        // emit
        if (core.startsWith('emit ')) {
          const m = core.match(/^emit\s+(.+?)(\s+as\s+"([^"]+)")?$/);
          if (!m) {
            errors.push({ line: lineNo, msg: 'Invalid emit statement.'});
            return;
          }
          emits.push({ line: lineNo, expr: m[1].trim(), format: m[3] || null });
          return;
        }

        // import
        if (core.startsWith('import ')) {
          warnings.push({ line: lineNo, msg: 'Import statements are runtime-dependent (may be unsupported).' });
          return;
        }

        warnings.push({ line: lineNo, msg: 'Unknown statement (ignored by preview compiler).' });
      }

      // Join multiline statements by accumulating until semicolon.
      for (let i = 0; i < lines.length; i++) {
        const lineNo = i + 1;
        const l = stripComments(lines[i]);
        if (!l) continue;
        if (!stmtBuf) stmtStartLine = lineNo;
        stmtBuf += (stmtBuf ? ' ' : '') + l;
        if (l.includes(';')) {
          // naive split on ; to support multiple statements per line
          const parts = stmtBuf.split(';');
          for (let p = 0; p < parts.length - 1; p++) {
            pushStmt(parts[p] + ';', stmtStartLine);
          }
          stmtBuf = parts[parts.length - 1].trim();
        }
      }
      if (stmtBuf.trim()) {
        errors.push({ line: stmtStartLine, msg: 'Unterminated statement (missing ;)'});
      }

      // Some safety-oriented lint.
      if (settings.allow_unsafe && /true/.test(String(settings.allow_unsafe))) {
        warnings.push({ line: 1, msg: 'allow_unsafe=true disables safety defaults. Use only with explicit policy.' });
      }
      if (emits.length === 0) {
        warnings.push({ line: 1, msg: 'No emit statement found — program has no outputs.' });
      }
      if (constraints.length === 0) {
        warnings.push({ line: 1, msg: 'No constraints found — consider adding norm/alpha bounds.' });
      }

      return {
        ok: errors.length === 0,
        errors,
        warnings,
        manifest: {
          settings,
          bindings: Object.values(lets),
          constraints,
          emits,
        },
      };
    }

    function render(result) {
      if (result.ok) {
        const warnCount = result.warnings.length;
        validationEl.textContent = warnCount
          ? `✔ Valid (preview).  Warnings: ${warnCount}\n\n` + result.warnings.map(w => `• line ${w.line}: ${w.msg}`).join('\n')
          : '✔ Valid (preview).';
      } else {
        validationEl.textContent = `✖ Invalid.\n\n` + result.errors.map(e => `• line ${e.line}: ${e.msg}`).join('\n');
      }
      manifestEl.textContent = JSON.stringify(result.manifest, null, 2);
    }

    document.querySelectorAll('.ls-tab').forEach((btn) => {
      btn.addEventListener('click', () => setActiveTab(btn.dataset.example));
    });

    runBtn?.addEventListener('click', () => {
      const res = validateLatentScript(editor.value || '');
      render(res);
    });

    resetBtn?.addEventListener('click', () => setActiveTab(currentExample));

    // Initialize
    setActiveTab('shift');
    const res0 = validateLatentScript(editor.value || '');
    render(res0);
  </script>

</Base>
