---
// Author: Bubba (claude-sonnet-4-6)
// Date: 2026-03-21
// PURPOSE: Individual research paper page — academic journal design.
//          Two-column layout (sidebar + body), serif body text, PDF-like presentation.
// SRP/DRY check: Pass — single responsibility, reuses Base layout
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const papers = await getCollection('research');
  return papers.map((paper) => ({
    params: { slug: paper.data.slug ?? paper.slug },
    props: { paper },
  }));
}

const { paper } = Astro.props;
const { Content } = await paper.render();

const statusConfig: Record<string, { label: string; classes: string }> = {
  preprint:  { label: 'Preprint',  classes: 'bg-amber-400/15 text-amber-300 border border-amber-400/40' },
  published: { label: 'Published', classes: 'bg-edge-green/15 text-edge-green border border-edge-green/40' },
  draft:     { label: 'Draft',     classes: 'bg-text-muted/10 text-text-muted border border-border' },
};
const status = statusConfig[paper.data.status] ?? statusConfig.draft;

// Format date nicely
const dateObj = new Date(paper.data.date);
const formattedDate = dateObj.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric'
});
---

<Base
  title={paper.data.title}
  description={paper.data.abstract ?? paper.data.summary ?? paper.data.title}
  ogType="article"
>
  <!-- Dark outer shell — like PDF reader chrome -->
  <div class="min-h-screen bg-bg-primary py-8 px-2 sm:px-4">

    <!-- Narrow top bar -->
    <div class="max-w-6xl mx-auto mb-4 flex items-center justify-between text-xs font-mono text-text-muted">
      <a href="/research" class="hover:text-node-blue transition-colors">← Lobster Research Collective</a>
      <span class="text-text-muted/50">VoynichLabs · {formattedDate}</span>
    </div>

    <!-- Paper sheet — white/off-white on dark background -->
    <div class="max-w-6xl mx-auto bg-[#f9f8f5] text-[#1a1a2e] rounded shadow-2xl shadow-black/60 overflow-hidden">

      <!-- Paper header band -->
      <div class="border-b border-[#d0cfc8] px-8 py-6 bg-[#f3f2ef]">
        <!-- Attribution + status row -->
        <div class="flex flex-wrap items-center gap-3 mb-4">
          <span class={`text-xs font-mono px-2.5 py-1 rounded-full font-semibold tracking-wide ${status.classes}`}>
            {status.label}
          </span>
          <span class="text-xs font-mono text-[#6b6b85] bg-[#e8e7e0] px-2.5 py-1 rounded-full">
            Generated by AutoResearchClaw
          </span>
        </div>

        <!-- Title -->
        <h1 class="font-serif text-2xl sm:text-3xl lg:text-4xl font-bold text-[#0f0f1a] leading-tight mb-4">
          {paper.data.title}
        </h1>

        <!-- Authors + date row -->
        <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-[#4a4a6a]">
          {paper.data.authors.map((author, i) => (
            <span class="font-medium">{author}{i < paper.data.authors.length - 1 ? '' : ''}</span>
          ))}
          <span class="text-[#9a9ab0]">·</span>
          <time class="font-mono text-xs text-[#6b6b85]">{formattedDate}</time>
        </div>
      </div>

      <!-- Two-column layout -->
      <div class="flex flex-col lg:flex-row">

        <!-- LEFT SIDEBAR — narrow, sticky on desktop -->
        <aside class="lg:w-64 xl:w-72 flex-shrink-0 border-b lg:border-b-0 lg:border-r border-[#d0cfc8] bg-[#f3f2ef]">
          <div class="lg:sticky lg:top-8 p-6 space-y-6">

            <!-- Status -->
            <div>
              <h3 class="text-[10px] font-mono font-bold uppercase tracking-widest text-[#9a9ab0] mb-2">Status</h3>
              <span class={`inline-block text-xs font-mono px-2 py-0.5 rounded-full ${status.classes}`}>
                {status.label}
              </span>
            </div>

            <!-- Authors -->
            <div>
              <h3 class="text-[10px] font-mono font-bold uppercase tracking-widest text-[#9a9ab0] mb-2">Authors</h3>
              <ul class="space-y-1">
                {paper.data.authors.map((author) => (
                  <li class="text-sm text-[#2a2a4a] font-medium">{author}</li>
                ))}
              </ul>
            </div>

            <!-- Published -->
            <div>
              <h3 class="text-[10px] font-mono font-bold uppercase tracking-widest text-[#9a9ab0] mb-2">Published</h3>
              <time class="text-sm text-[#2a2a4a]">{formattedDate}</time>
            </div>

            <!-- Keywords / Tags -->
            {paper.data.tags.length > 0 && (
              <div>
                <h3 class="text-[10px] font-mono font-bold uppercase tracking-widest text-[#9a9ab0] mb-2">Keywords</h3>
                <div class="flex flex-wrap gap-1.5">
                  {paper.data.tags.map((tag) => (
                    <span class="text-[10px] font-mono bg-[#e0dfd8] text-[#4a4a6a] px-2 py-0.5 rounded border border-[#c8c7c0]">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
            )}

            <!-- Abstract summary in sidebar -->
            {paper.data.abstract && (
              <div>
                <h3 class="text-[10px] font-mono font-bold uppercase tracking-widest text-[#9a9ab0] mb-2">Abstract</h3>
                <p class="text-xs text-[#4a4a6a] leading-relaxed line-clamp-[12]">
                  {paper.data.abstract}
                </p>
              </div>
            )}

            <!-- Back link -->
            <div class="pt-2 border-t border-[#d0cfc8]">
              <a href="/research" class="text-xs font-mono text-[#3b7fd4] hover:text-[#2563eb] transition-colors">
                ← All Papers
              </a>
            </div>
          </div>
        </aside>

        <!-- RIGHT COLUMN — paper body -->
        <main class="flex-1 min-w-0 px-8 py-8 lg:px-12 lg:py-10">

          <!-- Paper body — academic prose styling -->
          <div class="
            font-serif text-base lg:text-[17px] leading-relaxed text-[#1a1a2e]
            max-w-none

            [&_h2]:font-serif [&_h2]:text-xl [&_h2]:lg:text-2xl [&_h2]:font-bold
            [&_h2]:text-[#0f0f1a] [&_h2]:mt-10 [&_h2]:mb-4
            [&_h2]:pb-2 [&_h2]:border-b [&_h2]:border-[#d0cfc8]

            [&_h3]:font-serif [&_h3]:text-lg [&_h3]:font-semibold
            [&_h3]:text-[#1a1a3a] [&_h3]:mt-7 [&_h3]:mb-3

            [&_h4]:font-sans [&_h4]:text-sm [&_h4]:font-bold [&_h4]:uppercase
            [&_h4]:tracking-wide [&_h4]:text-[#4a4a6a] [&_h4]:mt-5 [&_h4]:mb-2

            [&_p]:mb-4 [&_p]:text-[#1a1a2e]

            [&_strong]:font-bold [&_strong]:text-[#0f0f1a]
            [&_em]:italic

            [&_a]:text-[#2563eb] [&_a]:underline [&_a]:underline-offset-2
            hover:[&_a]:text-[#1d4ed8]

            [&_ul]:mb-4 [&_ul]:pl-6 [&_ul]:list-disc
            [&_ol]:mb-4 [&_ol]:pl-6 [&_ol]:list-decimal
            [&_li]:mb-1.5 [&_li]:text-[#1a1a2e]

            [&_hr]:my-8 [&_hr]:border-[#d0cfc8]

            [&_code]:font-mono [&_code]:text-sm [&_code]:bg-[#e8e7e0]
            [&_code]:text-[#2a2a4a] [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:rounded

            [&_pre]:bg-[#1a1a2e] [&_pre]:text-[#e8e8f0] [&_pre]:rounded
            [&_pre]:p-4 [&_pre]:mb-4 [&_pre]:overflow-x-auto [&_pre]:text-sm
            [&_pre_code]:bg-transparent [&_pre_code]:text-[#e8e8f0] [&_pre_code]:p-0

            [&_blockquote]:border-l-4 [&_blockquote]:border-[#3b7fd4]
            [&_blockquote]:pl-4 [&_blockquote]:my-6 [&_blockquote]:text-[#4a4a6a]
            [&_blockquote]:bg-[#eef2fa] [&_blockquote]:py-3 [&_blockquote]:pr-4
            [&_blockquote]:rounded-r

            [&_img]:max-w-full [&_img]:rounded [&_img]:border [&_img]:border-[#d0cfc8]
            [&_img]:my-4

            [&_figure]:my-6
            [&_figcaption]:text-sm [&_figcaption]:text-[#6b6b85] [&_figcaption]:mt-2
            [&_figcaption]:font-sans [&_figcaption]:text-center
          ">

            <!-- Abstract inset box (if abstract section comes from content, style it specially) -->
            <!-- The ## Abstract heading + first blockquote get special treatment via CSS below -->

            <style>
              /* Abstract section styled as inset box */
              .paper-body > h2:first-of-type + p,
              .paper-body h2:first-of-type ~ p:first-of-type {
                /* handled inline */
              }

              /* Table styling: borders + alternating rows */
              .paper-body table {
                width: 100%;
                border-collapse: collapse;
                margin: 1.5rem 0;
                font-size: 0.875rem;
                font-family: 'Inter', system-ui, sans-serif;
              }
              .paper-body table thead tr {
                background: #2a2a4a;
                color: #f0f0f8;
              }
              .paper-body table thead th {
                padding: 0.6rem 0.85rem;
                text-align: left;
                font-weight: 600;
                font-size: 0.8rem;
                border: 1px solid #1a1a2e;
              }
              .paper-body table tbody tr {
                background: #f9f8f5;
                border-bottom: 1px solid #d0cfc8;
              }
              .paper-body table tbody tr:nth-child(even) {
                background: #f0efe8;
              }
              .paper-body table tbody td {
                padding: 0.55rem 0.85rem;
                border: 1px solid #d0cfc8;
                vertical-align: top;
                line-height: 1.4;
              }
              .paper-body table caption,
              .paper-body table + p > strong {
                font-style: italic;
                color: #6b6b85;
                font-size: 0.85rem;
                margin-top: 0.5rem;
                display: block;
              }

              /* Abstract: the first h2 section gets a special inset box */
              .paper-body-abstract {
                background: #eef2fa;
                border: 1px solid #b8c8e8;
                border-radius: 4px;
                padding: 1.25rem 1.5rem;
                margin-bottom: 2rem;
              }
              .paper-body-abstract p {
                margin-bottom: 0.5rem;
                font-size: 0.95rem;
                color: #2a2a4a;
              }
              .paper-body-abstract p:last-child {
                margin-bottom: 0;
              }
              .paper-body-abstract strong {
                font-weight: 700;
                color: #1a1a3a;
              }
            </style>

            <div class="paper-body">
              <Content />
            </div>
          </div>

          <!-- Footer -->
          <footer class="mt-12 pt-6 border-t border-[#d0cfc8]">
            <div class="flex flex-wrap items-center justify-between gap-4 text-xs font-mono text-[#9a9ab0]">
              <span>Generated by <strong class="text-[#6b6b85]">AutoResearchClaw</strong> · VoynichLabs</span>
              <a href="/research" class="text-[#3b7fd4] hover:text-[#2563eb] transition-colors">← All Research Papers</a>
            </div>
          </footer>

        </main>
      </div>
    </div>

    <!-- Bottom spacer -->
    <div class="max-w-6xl mx-auto mt-4 text-center text-xs font-mono text-text-muted/40">
      VoynichLabs Research · {new Date().getFullYear()}
    </div>
  </div>
</Base>
