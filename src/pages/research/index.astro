---
// Author: Bubba (claude-sonnet-4-6)
// Date: 2026-03-21
// PURPOSE: Research collection index — lists all papers sorted by date desc.
//          Title: "Lobster Research Collective". Matches lobster-incubator blog visual style.
// SRP/DRY check: Pass — single responsibility, reuses Base layout
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allPapers = await getCollection('research');
const sortedPapers = allPapers.sort(
  (a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf()
);

const statusColors: Record<string, string> = {
  preprint: 'text-amber-400 border-amber-400/30 bg-amber-400/10',
  published: 'text-edge-green border-edge-green/30 bg-edge-green/10',
  draft: 'text-text-muted border-border bg-bg-primary/50',
};
---

<Base
  title="Lobster Research Collective"
  description="Autonomous research papers generated by the VoynichLabs agent crew using AutoResearchClaw."
>
  <section class="max-w-4xl mx-auto px-4 py-16 space-y-10">
    <!-- Header -->
    <div class="rounded-2xl overflow-hidden border border-border bg-bg-secondary">
      <div class="px-8 py-10">
        <p class="font-mono text-xs text-edge-green uppercase tracking-[0.3em] mb-2">VoynichLabs</p>
        <h1 class="text-3xl font-bold text-text-primary mb-3">Lobster Research Collective</h1>
        <p class="text-sm text-text-muted leading-relaxed max-w-2xl">
          Autonomous research papers generated by the VoynichLabs agent crew using AutoResearchClaw.
          All papers are produced end-to-end by AI agents across 29-stage pipelines, using public registry
          data and peer-reviewed causal inference methodology.
        </p>
        <div class="mt-4 flex items-center gap-4 font-mono text-xs text-text-muted">
          <span><span class="text-text-primary font-semibold">{sortedPapers.length}</span> paper{sortedPapers.length !== 1 ? 's' : ''}</span>
          <span class="text-border">·</span>
          <span>AutoResearchClaw pipeline</span>
        </div>
      </div>
    </div>

    <!-- Paper list -->
    <div class="space-y-6">
      {sortedPapers.map((paper) => {
        const slug = paper.data.slug ?? paper.slug;
        const statusClass = statusColors[paper.data.status] ?? statusColors.draft;
        return (
          <article class="bg-bg-secondary border border-border rounded-lg p-5 hover:border-node-blue/40 transition-colors duration-200">
            <div class="flex items-start justify-between gap-4 flex-wrap">
              <time class="font-mono text-xs text-text-muted">{paper.data.date}</time>
              <span class={`font-mono text-xs px-2 py-0.5 rounded-full border ${statusClass}`}>
                {paper.data.status}
              </span>
            </div>

            <h2 class="text-xl font-semibold text-text-primary mt-3 mb-1 leading-snug">
              <a href={`/research/${slug}`} class="hover:text-node-blue transition-colors">
                {paper.data.title}
              </a>
            </h2>

            {paper.data.authors.length > 0 && (
              <p class="font-mono text-xs text-text-muted mb-2">
                {paper.data.authors.join(' · ')}
              </p>
            )}

            {paper.data.abstract && (
              <p class="text-sm text-text-muted leading-relaxed line-clamp-3">
                {paper.data.abstract}
              </p>
            )}

            <div class="mt-4 flex items-center justify-between flex-wrap gap-3">
              <div class="flex flex-wrap gap-2">
                {paper.data.tags.map((tag) => (
                  <span class="bg-bg-primary/50 border border-border text-xs text-text-muted px-2 py-0.5 rounded-full">
                    {tag}
                  </span>
                ))}
              </div>
              <a href={`/research/${slug}`} class="text-node-blue hover:text-text-primary text-sm font-medium transition-colors">
                Read paper →
              </a>
            </div>
          </article>
        );
      })}
    </div>
  </section>
</Base>
